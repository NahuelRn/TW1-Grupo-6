package com.tallerwebi.dominio;

import java.time.LocalDate;
import java.util.HashMap;
import java.util.Locale;
import java.util.Map;
import java.util.Random;
import java.util.function.BiFunction;
import javax.transaction.Transactional;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;

@SuppressWarnings("PMD.TooManyFields")
@Service
@Transactional
public class ServicioCombateImpl implements ServicioCombate {

  private static final int VALOR_NULO = 0;
  private static final int DIVISOR_MITAD = 2;
  private static final String TIPO_ATAQUE = "ATAQUE";
  private static final String TIPO_DEFENSA = "DEFENSA";

  // Códigos de efecto para las cartas de utilidad (tipo HECHIZO)
  private static final String EFECTO_CURA = "CURA";
  private static final String EFECTO_DANIO_DIRECTO = "DANIO_DIRECTO";
  private static final String EFECTO_BUFF_DANIO = "BUFF_DANIO";
  private static final String EFECTO_MULTIPLICADOR_DANIO = "MULTIPLICADOR_DANIO";
  private static final String EFECTO_EVASION = "EVASION";
  private static final String EFECTO_ATURDIR_ENEMIGO = "ATURDIR_ENEMIGO";
  private static final String EFECTO_DANIO_Y_ATURDIR = "DANIO_Y_ATURDIR";
  private static final String EFECTO_MITAD_VIDA_ENEMIGO = "MITAD_VIDA_ENEMIGO";
  private static final String EFECTO_SACRIFICIO = "SACRIFICIO";
  private static final String EFECTO_SACRIFICIO_BUFF = "SACRIFICIO_BUFF";
  private static final String EFECTO_VAMPIRISMO = "VAMPIRISMO";
  private static final String EFECTO_HIBRIDO_CURA_BUFF = "HIBRIDO_CURA_BUFF";
  private static final String EFECTO_HIBRIDO_ESCUDO_BUFF = "HIBRIDO_ESCUDO_BUFF";
  private static final String EFECTO_DANIO_ALEATORIO = "DANIO_ALEATORIO";
  private static final String EFECTO_RECICLAR = "RECICLAR";
  private static final String EFECTO_ATURDIR_Y_CURA = "ATURDIR_Y_CURA";
  private static final String EFECTO_INMORTALIDAD = "INMORTALIDAD";
  private static final String TXT_USAS = "Usas [";
  private static final String TXT_DANIO = " de daño.";
  private static final String TXT_HP = " HP.";

  @Value("${partida.hp.jugador.maximo:100}")
  private int hpMaximo = 100;

  @Value("${enemigo.dano.min.default:3}")
  private int dmgMinDefault = 3;

  @Value("${enemigo.dano.max.default:8}")
  private int dmgMaxDefault = 8;

  private RepositorioPartida repositorioPartida;
  private RepositorioCarta repositorioCarta;
  private RepositorioHistorialPartida repositorioHistorialPartida;
  private ServicioCalculoRecompensa servicioCalculoRecompensa;
  private final ServicioUsuario servicioUsuario;
  private Random random = new Random();

  private final Map<String, BiFunction<Partida, Carta, EfectoHechizoResultado>> efectosHechizo =
          crearMapaDeEfectos();

  @Autowired
  public ServicioCombateImpl(
          RepositorioPartida repositorioPartida,
          RepositorioCarta repositorioCarta,
          RepositorioHistorialPartida repositorioHistorialPartida,
          ServicioUsuario servicioUsuario,
          ServicioCalculoRecompensa servicioCalculoRecompensa
  ) {
    this.repositorioPartida = repositorioPartida;
    this.repositorioCarta = repositorioCarta;
    this.repositorioHistorialPartida = repositorioHistorialPartida;
    this.servicioUsuario = servicioUsuario;
    this.servicioCalculoRecompensa = servicioCalculoRecompensa;
  }

  @Override
  public Map<String, String> obtenerConfiguracionZona(String zona) {
    Map<String, String> config = new HashMap<>();
    String zonaSegura = (zona != null) ? zona : "bosque";
    boolean esBosque = "bosque".equalsIgnoreCase(zonaSegura);

    config.put("nombreZona", zonaSegura.toUpperCase(Locale.ROOT));
    config.put("archivoFondo", esBosque ? "Bosque.jpg" : "Cueva.jpg");
    return config;
  }

  @Override
  @SuppressWarnings("PMD.DataflowAnomalyAnalysis")
  public String jugarTurno(Long idPartida, Long idCarta) {
    Partida partida = repositorioPartida.buscarPartidaPorIdentificador(idPartida);
    Carta carta = repositorioCarta.buscarPorId(idCarta);
    Enemigo enemigo = partida.getEnemigo();
    String nombreEnemigo = (enemigo != null) ? enemigo.getNombre() : "Enemigo";

    EfectoHechizoResultado efecto = resolverAccionJugador(partida, carta);
    String accionJugador = efecto.getMensaje();

    if (partida.getHpEnemigo() <= VALOR_NULO) {
      return registrarVictoria(partida, accionJugador, nombreEnemigo);
    }

    int danioRecibido = aplicarContraataqueEnemigo(partida, enemigo, efecto);

    if (partida.getHpJugador() <= VALOR_NULO) {
      return registrarDerrota(partida, accionJugador, nombreEnemigo, danioRecibido);
    }

    repositorioPartida.actualizar(partida);
    return construirMensajeFinal(accionJugador, nombreEnemigo, danioRecibido, efecto, carta);
  }

  private EfectoHechizoResultado resolverAccionJugador(Partida partida, Carta carta) {
    if (TIPO_ATAQUE.equalsIgnoreCase(carta.getTipo())) {
      return new EfectoHechizoResultado(resolverAtaque(partida, carta));
    }
    if (TIPO_DEFENSA.equalsIgnoreCase(carta.getTipo())) {
      return resolverDefensa(carta);
    }
    return resolverEfectoHechizo(partida, carta);
  }

  private String resolverAtaque(Partida partida, Carta carta) {
    int danioBase = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    int buff = valorSeguro(partida.getBuffDanioProximoAtaque(), VALOR_NULO);
    int multiplicador = Math.max(1, valorSeguro(partida.getMultiplicadorDanioProximoAtaque(), 1));
    int danioFinal = (danioBase + buff) * multiplicador;

    partida.setHpEnemigo(partida.getHpEnemigo() - danioFinal);
    partida.setBuffDanioProximoAtaque(VALOR_NULO);
    partida.setMultiplicadorDanioProximoAtaque(1);

    return "Atacas con [" + carta.getNombre() + "] haciendo " + danioFinal + TXT_DANIO;
  }

  private EfectoHechizoResultado resolverDefensa(Carta carta) {
    int defensa = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    EfectoHechizoResultado resultado = new EfectoHechizoResultado(
            "Te cubrís con [" + carta.getNombre() + "], logrando " + defensa + " de escudo."
    );
    resultado.setDefensaGenerada(defensa);
    return resultado;
  }

  private int aplicarContraataqueEnemigo(
          Partida partida,
          Enemigo enemigo,
          EfectoHechizoResultado efecto
  ) {
    int danioRecibido = efecto.isAnularAtaqueEnemigo()
            ? VALOR_NULO
            : Math.max(VALOR_NULO, calcularAtaqueEnemigo(enemigo) - efecto.getDefensaGenerada());

    partida.setHpJugador(partida.getHpJugador() - danioRecibido);

    if (partida.getHpJugador() <= VALOR_NULO && efecto.isProteccionMortal()) {
      partida.setHpJugador(1);
    }

    return danioRecibido;
  }

  private String registrarVictoria(Partida partida, String accionJugador, String nombreEnemigo) {
    partida.setEnumEstadoPartida(EnumEstadoPartida.GANADOR_JUGADOR);
    this.servicioUsuario.aplicarRecompensa(partida.getUsuario(), partida);
    RecompensaDTO recompensaDTO = this.servicioCalculoRecompensa.obtenerRecompensa(partida);

    HistorialPartida historialPartida = new HistorialPartida();
    historialPartida.setUsuario(partida.getUsuario());
    historialPartida.setResultado("GANADOR_JUGADOR");
    historialPartida.setOroGanado(recompensaDTO.getOro());
    historialPartida.setExperienciaGanada(recompensaDTO.getExperiencia());
    historialPartida.setFecha(LocalDate.now());
    this.repositorioHistorialPartida.guardarHistorialPartidaRepositorio(historialPartida);

    repositorioPartida.actualizar(partida);
    return accionJugador + " ¡" + nombreEnemigo.toUpperCase(Locale.ROOT) + " HA SIDO DERROTADO!";
  }

  private String registrarDerrota(
          Partida partida,
          String accionJugador,
          String nombreEnemigo,
          int danioRecibido
  ) {
    partida.setEnumEstadoPartida(EnumEstadoPartida.GANADOR_ENEMIGO);

    HistorialPartida historialPartida = new HistorialPartida();
    historialPartida.setUsuario(partida.getUsuario());
    historialPartida.setResultado("GANADOR_ENEMIGO");
    historialPartida.setOroGanado(0);
    historialPartida.setExperienciaGanada(10);
    historialPartida.setFecha(LocalDate.now());
    this.repositorioHistorialPartida.guardarHistorialPartidaRepositorio(historialPartida);

    repositorioPartida.actualizar(partida);
    return (
            accionJugador +
                    " " +
                    nombreEnemigo +
                    " te mató con " +
                    danioRecibido +
                    " de daño. FIN DE LA PARTIDA."
    );
  }

  private String construirMensajeFinal(
          String accionJugador,
          String nombreEnemigo,
          int danioRecibido,
          EfectoHechizoResultado efecto,
          Carta carta
  ) {
    if (efecto.isAnularAtaqueEnemigo()) {
      return accionJugador + " " + nombreEnemigo + " quedó aturdido y no pudo atacarte.";
    }
    if (danioRecibido == VALOR_NULO && TIPO_DEFENSA.equalsIgnoreCase(carta.getTipo())) {
      return accionJugador + " ¡Bloqueo perfecto! Evitaste el ataque de " + nombreEnemigo + ".";
    }
    return (
            accionJugador + " " + nombreEnemigo + " contraataca y recibes " + danioRecibido + TXT_DANIO
    );
  }

  // ==========================================================
  // Resolución de efectos de las cartas de utilidad (HECHIZO)
  // ==========================================================

  private EfectoHechizoResultado resolverEfectoHechizo(Partida partida, Carta carta) {
    BiFunction<Partida, Carta, EfectoHechizoResultado> efecto = efectosHechizo.get(
            carta.getEfecto()
    );
    if (efecto == null) {
      return efectoCuraGenerica(partida, carta);
    }
    return efecto.apply(partida, carta);
  }

  private Map<String, BiFunction<Partida, Carta, EfectoHechizoResultado>> crearMapaDeEfectos() {
    Map<String, BiFunction<Partida, Carta, EfectoHechizoResultado>> mapa = new HashMap<>();
    mapa.put(EFECTO_CURA, this::efectoCuraGenerica);
    mapa.put(EFECTO_DANIO_DIRECTO, this::efectoDanioDirecto);
    mapa.put(EFECTO_BUFF_DANIO, this::efectoBuffDanio);
    mapa.put(EFECTO_MULTIPLICADOR_DANIO, this::efectoMultiplicadorDanio);
    mapa.put(EFECTO_EVASION, this::efectoAturdirEnemigo);
    mapa.put(EFECTO_ATURDIR_ENEMIGO, this::efectoAturdirEnemigo);
    mapa.put(EFECTO_DANIO_Y_ATURDIR, this::efectoDanioYAturdir);
    mapa.put(EFECTO_MITAD_VIDA_ENEMIGO, this::efectoMitadVidaEnemigo);
    mapa.put(EFECTO_SACRIFICIO, this::efectoSacrificio);
    mapa.put(EFECTO_SACRIFICIO_BUFF, this::efectoSacrificioBuff);
    mapa.put(EFECTO_VAMPIRISMO, this::efectoVampirismo);
    mapa.put(EFECTO_HIBRIDO_CURA_BUFF, this::efectoHibridoCuraBuff);
    mapa.put(EFECTO_HIBRIDO_ESCUDO_BUFF, this::efectoHibridoEscudoBuff);
    mapa.put(EFECTO_DANIO_ALEATORIO, this::efectoDanioAleatorio);
    mapa.put(EFECTO_RECICLAR, this::efectoReciclar);
    mapa.put(EFECTO_ATURDIR_Y_CURA, this::efectoAturdirYCura);
    mapa.put(EFECTO_INMORTALIDAD, this::efectoInmortalidad);
    return mapa;
  }

  private EfectoHechizoResultado efectoCuraGenerica(Partida partida, Carta carta) {
    int curacion = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    partida.setHpJugador(Math.min(hpMaximo, partida.getHpJugador() + curacion));
    return new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "] y recuperas " + curacion + " HP."
    );
  }

  private EfectoHechizoResultado efectoDanioDirecto(Partida partida, Carta carta) {
    int danio = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    partida.setHpEnemigo(partida.getHpEnemigo() - danio);
    return new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "] infligiendo " + danio + " de daño directo."
    );
  }

  private EfectoHechizoResultado efectoBuffDanio(Partida partida, Carta carta) {
    int buff = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    partida.setBuffDanioProximoAtaque(valorSeguro(partida.getBuffDanioProximoAtaque(), 0) + buff);
    return new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "]. Tu próximo ataque hará +" + buff + TXT_DANIO
    );
  }

  private EfectoHechizoResultado efectoMultiplicadorDanio(Partida partida, Carta carta) {
    int multiplicador = Math.max(1, calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax()));
    partida.setMultiplicadorDanioProximoAtaque(multiplicador);
    return new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "]. Tu próximo ataque hará x" + multiplicador + TXT_DANIO
    );
  }

  @SuppressWarnings("PMD.UnusedFormalParameter")
  private EfectoHechizoResultado efectoAturdirEnemigo(Partida partida, Carta carta) {
    EfectoHechizoResultado resultado = new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "]. El enemigo queda aturdido."
    );
    resultado.setAnularAtaqueEnemigo(true);
    return resultado;
  }

  private EfectoHechizoResultado efectoDanioYAturdir(Partida partida, Carta carta) {
    int danio = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    partida.setHpEnemigo(partida.getHpEnemigo() - danio);
    EfectoHechizoResultado resultado = new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "] haciendo " + danio + " de daño y aturdiendo al enemigo."
    );
    resultado.setAnularAtaqueEnemigo(true);
    return resultado;
  }

  private EfectoHechizoResultado efectoMitadVidaEnemigo(Partida partida, Carta carta) {
    int hpActual = valorSeguro(partida.getHpEnemigo(), 0);
    partida.setHpEnemigo(hpActual / DIVISOR_MITAD);
    return new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "]. La vida del enemigo se reduce a la mitad."
    );
  }

  private EfectoHechizoResultado efectoSacrificio(Partida partida, Carta carta) {
    int danioEnemigo = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    int danioPropio = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    partida.setHpEnemigo(partida.getHpEnemigo() - danioEnemigo);
    partida.setHpJugador(partida.getHpJugador() - danioPropio);
    return new EfectoHechizoResultado(
            TXT_USAS +
                    carta.getNombre() +
                    "]. Pierdes " +
                    danioPropio +
                    " HP y el enemigo pierde " +
                    danioEnemigo +
                    " HP."
    );
  }

  private EfectoHechizoResultado efectoSacrificioBuff(Partida partida, Carta carta) {
    int danioPropio = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    int buff = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    partida.setHpJugador(partida.getHpJugador() - danioPropio);
    partida.setBuffDanioProximoAtaque(valorSeguro(partida.getBuffDanioProximoAtaque(), 0) + buff);
    return new EfectoHechizoResultado(
            TXT_USAS +
                    carta.getNombre() +
                    "]. Pierdes " +
                    danioPropio +
                    " HP, pero tu próximo ataque hará +" +
                    buff +
                    TXT_DANIO
    );
  }

  private EfectoHechizoResultado efectoVampirismo(Partida partida, Carta carta) {
    int danio = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    int curacion = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    partida.setHpEnemigo(partida.getHpEnemigo() - danio);
    partida.setHpJugador(Math.min(hpMaximo, partida.getHpJugador() + curacion));
    return new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "]. Haces " + danio + " de daño y te curas " + curacion + " HP."
    );
  }

  private EfectoHechizoResultado efectoHibridoCuraBuff(Partida partida, Carta carta) {
    int curacion = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    int buff = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    partida.setHpJugador(Math.min(hpMaximo, partida.getHpJugador() + curacion));
    partida.setBuffDanioProximoAtaque(valorSeguro(partida.getBuffDanioProximoAtaque(), 0) + buff);
    return new EfectoHechizoResultado(
            TXT_USAS +
                    carta.getNombre() +
                    "]. Te curas " +
                    curacion +
                    " HP y tu próximo ataque hará +" +
                    buff +
                    TXT_DANIO
    );
  }

  private EfectoHechizoResultado efectoHibridoEscudoBuff(Partida partida, Carta carta) {
    int escudo = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    int buff = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    partida.setBuffDanioProximoAtaque(valorSeguro(partida.getBuffDanioProximoAtaque(), 0) + buff);
    EfectoHechizoResultado resultado = new EfectoHechizoResultado(
            TXT_USAS +
                    carta.getNombre() +
                    "]. Ganas " +
                    escudo +
                    " de escudo este turno y tu próximo ataque hará +" +
                    buff +
                    TXT_DANIO
    );
    resultado.setDefensaGenerada(escudo);
    return resultado;
  }

  private EfectoHechizoResultado efectoDanioAleatorio(Partida partida, Carta carta) {
    int danio = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    partida.setHpEnemigo(partida.getHpEnemigo() - danio);
    return new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "] y la magia inflige " + danio + " de daño aleatorio."
    );
  }

  private EfectoHechizoResultado efectoReciclar(Partida partida, Carta carta) {
    int curacion = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    int vidaEnemigoExtra = calcularValorAleatorio(carta.getDanoMin(), carta.getDanoMax());
    partida.setHpJugador(Math.min(hpMaximo, partida.getHpJugador() + curacion));
    partida.setHpEnemigo(partida.getHpEnemigo() + vidaEnemigoExtra);
    return new EfectoHechizoResultado(
            TXT_USAS +
                    carta.getNombre() +
                    "]. Te curas " +
                    curacion +
                    " HP, pero el enemigo recupera " +
                    vidaEnemigoExtra +
                    " HP."
    );
  }

  private EfectoHechizoResultado efectoAturdirYCura(Partida partida, Carta carta) {
    int curacion = calcularValorAleatorio(carta.getDefensaMin(), carta.getDefensaMax());
    partida.setHpJugador(Math.min(hpMaximo, partida.getHpJugador() + curacion));
    EfectoHechizoResultado resultado = new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "]. Te curas " + curacion + " HP y el enemigo no ataca."
    );
    resultado.setAnularAtaqueEnemigo(true);
    return resultado;
  }

  @SuppressWarnings("PMD.UnusedFormalParameter")
  private EfectoHechizoResultado efectoInmortalidad(Partida partida, Carta carta) {
    EfectoHechizoResultado resultado = new EfectoHechizoResultado(
            TXT_USAS + carta.getNombre() + "]. Si el golpe fuera mortal, sobrevivís con 1 HP."
    );
    resultado.setProteccionMortal(true);
    return resultado;
  }

  // ==========================================================
  // Helpers numéricos
  // ==========================================================

  private int calcularValorAleatorio(Integer min, Integer max) {
    int statMin = (min != null) ? min : VALOR_NULO;
    int statMax = (max != null) ? max : VALOR_NULO;

    if (statMax <= VALOR_NULO && statMin <= VALOR_NULO) return VALOR_NULO;
    if (statMin == statMax) return statMax;

    return random.nextInt((statMax - statMin) + 1) + statMin;
  }

  private int calcularAtaqueEnemigo(Enemigo enemigo) {
    int minDmg = (enemigo != null && enemigo.getDanoMin() != null)
            ? enemigo.getDanoMin()
            : dmgMinDefault;
    int maxDmg = (enemigo != null && enemigo.getDanoMax() != null)
            ? enemigo.getDanoMax()
            : dmgMaxDefault;

    if (minDmg == maxDmg) return maxDmg;
    return random.nextInt((maxDmg - minDmg) + 1) + minDmg;
  }

  private int valorSeguro(Integer valor, int porDefecto) {
    return (valor != null) ? valor : porDefecto;
  }

  @Override
  public Partida obtenerPartidaPorIdentificador(Long identificadorPartida) {
    return repositorioPartida.buscarPartidaPorIdentificador(identificadorPartida);
  }

  // ==========================================================
  // Resultado interno de resolver una acción del jugador
  // ==========================================================
  private static final class EfectoHechizoResultado {

    private final String mensaje;
    private int defensaGenerada = 0;
    private boolean anularAtaqueEnemigo = false;
    private boolean proteccionMortal = false;

    private EfectoHechizoResultado(String mensaje) {
      this.mensaje = mensaje;
    }

    private String getMensaje() {
      return mensaje;
    }

    private int getDefensaGenerada() {
      return defensaGenerada;
    }

    private void setDefensaGenerada(int defensaGenerada) {
      this.defensaGenerada = defensaGenerada;
    }

    private boolean isAnularAtaqueEnemigo() {
      return anularAtaqueEnemigo;
    }

    private void setAnularAtaqueEnemigo(boolean anularAtaqueEnemigo) {
      this.anularAtaqueEnemigo = anularAtaqueEnemigo;
    }

    private boolean isProteccionMortal() {
      return proteccionMortal;
    }

    private void setProteccionMortal(boolean proteccionMortal) {
      this.proteccionMortal = proteccionMortal;
    }
  }
}
