package com.tallerwebi.dominio;

import javax.transaction.Transactional;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

@Service
@Transactional
public class ServicioCombateImpl implements ServicioCombate {

  private RepositorioPartida repositorioPartida;
  private RepositorioCarta repositorioCarta;

  @Autowired
  public ServicioCombateImpl(RepositorioPartida repositorioPartida, RepositorioCarta repositorioCarta) {
    this.repositorioPartida = repositorioPartida;
    this.repositorioCarta = repositorioCarta;
  }

  @Override
  public String jugarTurno(Partida partida, Long idCarta) {
    Carta cartaJugada = repositorioCarta.buscarPorId(idCarta);

    // Obtenemos los stats de la carta
    int dano = (cartaJugada.getDano() != null) ? cartaJugada.getDano() : 0;
    int defensa = (cartaJugada.getDefensa() != null) ? cartaJugada.getDefensa() : 0;

    // 1. Fase de Ataque del Jugador
    partida.setHpEnemigo(partida.getHpEnemigo() - dano);

    // 2. Fase de Defensa (El bicho nos pega 5 fijos, lo bloqueamos con nuestra carta si es de defensa)
    int danoRecibido = 0;
    if (partida.getHpEnemigo() > 0) { // El Infectado solo contraataca si sigue vivo
      danoRecibido = 5 - defensa;
      if (danoRecibido < 0) danoRecibido = 0; // Evitamos que nos cure si la defensa es alta
      partida.setHpJugador(partida.getHpJugador() - danoRecibido);
    }

    // 3. Chequeo de victoria/derrota y armado del Log
    if (partida.getHpEnemigo() <= 0) {
      partida.setEnumEstadoPartida(EnumEstadoPartida.GANADOR_JUGADOR);
      return "¡EL INFECTADO HA SIDO DESTRUIDO! HAS GANADO. Tu golpe con [" + cartaJugada.getNombre() + "] fue letal.";
    } else if (partida.getHpJugador() <= 0) {
      partida.setEnumEstadoPartida(EnumEstadoPartida.GANADOR_ENEMIGO);
      return "HAS MUERTO. FIN DE LA PARTIDA.";
    } else {
      return "Usaste [" + cartaJugada.getNombre() + "]. " +
              (dano > 0 ? "Hiciste " + dano + " de Daño. " : "") +
              (defensa > 0 ? "Levantaste " + defensa + " de Escudo. " : "") +
              "El Infectado te sacó " + danoRecibido + " HP.";
    }
  }

  @Override
  public Partida obtenerPartidaPorIdentificador(Long identificadorPartida) {
    return this.repositorioPartida.buscarPartidaPorIdentificador(identificadorPartida);
  }
}
