<div class="row">
  <div th:each="carta : ${todasLasCartas}" class="col-md-3">
    <div th:classappend="${cartasQueTengo.contains(carta.id)} ? 'carta-activa' : 'carta-apagada'"
         class="mythic-panel text-center">

      <h5 th:text="${carta.nombre}">Nombre Carta</h5>
      <p th:text="${carta.descripcion}">Descripcion</p>
    </div>
  </div>
</div>