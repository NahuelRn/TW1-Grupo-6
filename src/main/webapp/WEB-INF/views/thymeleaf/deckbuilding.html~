<!DOCTYPE html>
<html lang="es" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MythicStack - Armado de Mazo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #0c0c0e !important; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #ffffff; }
        .titulo-seccion { color: #e63946; font-weight: 800; letter-spacing: 2px; text-shadow: 0 0 10px rgba(230,57,70,0.4); }
        .mythic-card { background-color: #131316 !important; border: 2px solid #e5a93b !important; border-radius: 12px !important; position: relative; box-shadow: 0 4px 15px rgba(0,0,0,0.7); transition: transform 0.2s, box-shadow 0.2s; }
        .mythic-card:hover { transform: translateY(-5px); box-shadow: 0 0 20px rgba(229,169,59,0.4); }
        .mythic-card.seleccionada { border-color: #e63946 !important; box-shadow: 0 0 20px rgba(230,57,70,0.6) !important; }
        .quantity-badge { position: absolute; top: -12px; right: -12px; background-color: #ff4d6d !important; color: white !important; font-weight: bold; font-size: 0.75rem; padding: 4px 8px; border-radius: 50%; border: 2px solid #e5a93b; box-shadow: 0 2px 5px rgba(0,0,0,0.5); z-index: 10; }
        .card-img-container { width: 100%; aspect-ratio: 7 / 10; background-color: #09090b; border-radius: 8px; overflow: hidden; border: 1px solid #27272a; }
        .card-img-container img { width: 100%; height: 100%; object-fit: cover; }
        .no-art { color: #52525b; font-size: 0.8rem; font-weight: 500; text-transform: uppercase; letter-spacing: 1px; border: 2px dashed #27272a; width: 90%; height: 90%; display: flex; align-items: center; justify-content: center; border-radius: 6px; }
        .card-title-mythic { font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 8px; color: #ffffff; }
        .badge-rarity { background-color: transparent !important; border: 1px solid #e5a93b !important; color: #e5a93b !important; font-size: 0.65rem; font-weight: 700; padding: 3px 6px; }
        .badge-type { background-color: #27272a !important; color: #ffffff !important; font-size: 0.65rem; font-weight: 700; padding: 3px 6px; }
        .card-desc-mythic { color: #a1a1aa !important; font-size: 0.75rem; margin-top: 8px; min-height: 35px; }
        .mythic-checkbox { width: 20px; height: 20px; accent-color: #e63946; cursor: pointer; }
        .contador-box { background-color: #131316; border: 2px solid #e5a93b; border-radius: 10px; padding: 10px 24px; display: inline-block; font-size: 1rem; font-weight: 700; color: #e5a93b; letter-spacing: 1px; }
        .contador-box.listo { border-color: #e63946; color: #e63946; box-shadow: 0 0 12px rgba(230,57,70,0.4); }
        .instruccion { color: #a1a1aa; font-size: 0.95rem; margin-top: 6px; }
    </style>
</head>
<body th:style="'background-image: url(' + @{/img/MazoFondo.jpg} + '); background-size: cover; background-position: center; background-attachment: fixed;'">

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="titulo-seccion">ARMADO DE MAZO</h1>
        <p style="color:#ffffff !important; font-size:1.1rem; font-weight:500; opacity:0.95;">
            Selecciona exactamente <strong style="color:#e5a93b;">15 cartas</strong> para formar tu mazo
        </p>
        <div class="mt-3">
            <span class="contador-box" id="contador-mazo">0 / 15 cartas seleccionadas</span>
        </div>
    </div>

    <div th:if="${error}" class="alert alert-danger text-center shadow" th:text="${error}"></div>

    <form th:action="@{/mazo/guardar}" method="POST">
        <div id="contenedor-cartas" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-4 px-3">

            <div class="col card-item-node" th:each="item : ${inventario}"
                 th:attr="data-rareza=${item.carta.rareza}">
                <div class="card h-100 mythic-card p-3">

                    <span class="quantity-badge" th:text="'x' + ${item.cantidad}">x1</span>

                    <div class="card-img-container">
                        <img th:if="${item.carta.imagen != null and not #strings.isEmpty(item.carta.imagen)}"
                             th:src="@{/img/{img}(img=${item.carta.imagen})}"
                             th:alt="${item.carta.nombre}">
                        <div th:unless="${item.carta.imagen != null and not #strings.isEmpty(item.carta.imagen)}"
                             class="no-art">
                            <span>Arte no disponible</span>
                        </div>
                    </div>

                    <div class="text-center mt-2">
                        <h5 class="card-title-mythic" th:text="${item.carta.nombre}">NOMBRE</h5>
                        <div class="d-flex justify-content-center gap-1 my-2">
                            <span class="badge badge-rarity"
                                  th:text="${item.carta.rareza != null} ? ${item.carta.rareza} : 'COMÚN'">COMÚN</span>
                            <span class="badge badge-type"
                                  th:text="${item.carta.tipo != null} ? ${item.carta.tipo} : 'TIPO'">ATAQUE</span>
                        </div>
                        <p class="card-desc-mythic"
                           th:text="${item.carta.descripcion != null} ? ${item.carta.descripcion} : 'Sin descripción disponible.'">
                            Efecto
                        </p>
                        <div class="form-check d-flex justify-content-center mt-2">
                            <input class="form-check-input mythic-checkbox checkbox-mazo"
                                   type="checkbox" name="cartasIds" th:value="${item.carta.id}">
                        </div>
                    </div>

                </div>
            </div>

        </div>

        <!-- Botón bloqueado hasta exactamente 15 -->
        <div class="text-center mt-5">
            <button type="submit" id="btn-guardar"
                    class="btn btn-danger btn-lg px-5 fw-bold shadow"
                    disabled>
                GUARDAR MAZO
            </button>
            <p class="instruccion mt-2" id="msg-mazo">
                Selecciona exactamente 15 cartas para habilitar el botón
            </p>
        </div>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const btnGuardar = document.getElementById("btn-guardar");
        const contador   = document.getElementById("contador-mazo");
        const msgMazo    = document.getElementById("msg-mazo");
        const MAX_CARTAS = 15;

        function actualizarContador() {
            const seleccionadas = document.querySelectorAll(".checkbox-mazo:checked").length;
            contador.textContent = seleccionadas + " / " + MAX_CARTAS + " cartas seleccionadas";

            if (seleccionadas === MAX_CARTAS) {
                contador.classList.add("listo");
                btnGuardar.disabled = false;
                msgMazo.textContent = "Mazo completo! Ya podes guardarlo";
                msgMazo.style.color = "#e63946";
            } else {
                contador.classList.remove("listo");
                btnGuardar.disabled = true;
                msgMazo.textContent = "Selecciona exactamente 15 cartas para habilitar el boton";
                msgMazo.style.color = "#a1a1aa";
            }
        }

        // Click en la card completa
        document.querySelectorAll(".mythic-card").forEach(function (card) {
            card.addEventListener("click", function () {
                const checkbox = card.querySelector(".checkbox-mazo");
                const seleccionadas = document.querySelectorAll(".checkbox-mazo:checked").length;

                // Bloquear si ya hay 15 y esta no está marcada
                if (!checkbox.checked && seleccionadas >= MAX_CARTAS) return;

                checkbox.checked = !checkbox.checked;
                card.classList.toggle("seleccionada", checkbox.checked);
                actualizarContador();
            });
        });

        document.querySelectorAll(".checkbox-mazo").forEach(function (cb) {
            cb.addEventListener("change", actualizarContador);
        });

        // Ordenar por rareza al cargar
        const contenedor  = document.getElementById("contenedor-cartas");
        const nodos       = Array.from(contenedor.querySelectorAll(".card-item-node"));
        const pesosRareza = { "Comun": 1, "Poco Comun": 2, "Rara": 3, "Exotica": 4, "Legendaria": 5 };

        nodos.sort(function (a, b) {
            const pesoA = pesosRareza[a.getAttribute("data-rareza")] || 99;
            const pesoB = pesosRareza[b.getAttribute("data-rareza")] || 99;
            return pesoA - pesoB;
        });
        nodos.forEach(function (nodo) { contenedor.appendChild(nodo); });

        actualizarContador();
    });
</script>
</body>
</html>