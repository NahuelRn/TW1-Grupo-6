<div class="panel-principal text-center">

    <h1 class="titulo-resultado">&#128221; Contrato Ejecutado!</h1>
    <p class="subtitulo">Los dioses de MythicStack han aceptado tu sacrificio.</p>

    <hr class="divider">

    <!-- CARTA OBTENIDA -->
    <div th:if="${cartaPremio}">

        <p style="color:#a09090; font-size:0.85rem; text-transform:uppercase; letter-spacing:2px; margin-bottom:16px;">
            Carta Obtenida
        </p>

        <div class="card-carta-obtenida">

            <!-- Imagen de la carta -->
            <img th:if="${cartaPremio.imagen != null and not #strings.isEmpty(cartaPremio.imagen)}"
                 th:src="@{/img/{img}(img=${cartaPremio.imagen})}"
                 th:alt="${cartaPremio.nombre}"
                 class="carta-imagen"/>
            <div th:unless="${cartaPremio.imagen != null and not #strings.isEmpty(cartaPremio.imagen)}"
                 class="carta-sin-imagen">
                <span>Sin imagen</span>
            </div>

            <!-- Nombre -->
            <h2 class="nombre-carta" th:text="${cartaPremio.nombre}">Nombre Carta</h2>

            <!-- Rareza y Tipo -->
            <div class="d-flex justify-content-center gap-2 flex-wrap mb-2">
                <span class="badge-rareza" th:text="${cartaPremio.rareza}">RAREZA</span>
                <span class="badge-tipo"
                      th:text="${cartaPremio.tipo != null and cartaPremio.subtipo != null}
                               ? ${cartaPremio.tipo + ' · ' + cartaPremio.subtipo}
                               : ${cartaPremio.tipo}">
                    TIPO
                </span>
            </div>

            <!-- Descripción -->
            <p class="descripcion-carta" th:text="${cartaPremio.descripcion}">
                Descripción de la carta obtenida.
            </p>

            <!-- Datos adicionales -->
            <div class="d-flex justify-content-around flex-wrap gap-2 mt-3">
                <span class="dato-carta">
                    Valor: <strong th:text="${cartaPremio.valorOroBase + ' Oro'}">100 Oro</strong>
                </span>
            </div>
        </div>

    </div>

    <!-- ERROR: no se encontró carta -->
    <div th:unless="${cartaPremio}" class="alert alert-danger mt-3">
        No se detectó ninguna carta obtenida. Volvé a intentar el proceso.
    </div>

    <hr class="divider">

    <!-- BOTÓN VOLVER -->
    <a th:href="@{/contrato-mejora(t=${#dates.createNow().getTime()})}"
       class="btn btn-mythic mt-2">
        Volver a Intentar
    </a>

</div>

</body>
</html>