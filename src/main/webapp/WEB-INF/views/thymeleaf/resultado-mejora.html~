<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>MythicStack - Contrato Firmado</title>
    <link rel="stylesheet" th:href="@{/css/bootstrap.min.css}">
    <link rel="stylesheet" th:href="@{/css/globals.css}">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #120c0c;
            color: #f0ead6;
            font-family: 'Roboto', sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
            background-image:
                    radial-gradient(ellipse at 20% 10%, rgba(139,0,0,0.2) 0%, transparent 50%),
                    radial-gradient(ellipse at 80% 90%, rgba(139,0,0,0.15) 0%, transparent 50%);
        }

        .panel-principal {
            background: radial-gradient(circle, rgba(50,10,10,1) 0%, rgba(10,5,5,1) 100%);
            border: 2px solid #d4af37;
            border-radius: 16px;
            box-shadow: 0 0 30px rgba(212,175,55,0.3), 0 0 60px rgba(212,175,55,0.1);
            width: 100%;
            max-width: 560px;
            padding: 45px 40px;
        }

        .titulo-resultado {
            font-family: 'Cinzel', serif;
            font-weight: 900;
            color: #d4af37;
            text-shadow: 0 0 20px rgba(212,175,55,0.5);
            font-size: 2rem;
            margin-bottom: 6px;
        }

        .subtitulo {
            color: #a09090;
            font-size: 0.95rem;
            margin-bottom: 30px;
        }

        /* ── CARD DE CARTA (mismo estilo que mercado-detalle-trade) ── */
        .card-carta-obtenida {
            background-color: #221515;
            border: 2px solid #d4af37;
            border-radius: 10px;
            padding: 24px 20px;
            margin-bottom: 10px;
        }

        .carta-imagen {
            width: 160px;
            height: 220px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid #4a1212;
            box-shadow: 0 0 20px rgba(212,175,55,0.25);
            margin: 0 auto 16px;
            display: block;
        }

        .carta-sin-imagen {
            width: 160px;
            height: 220px;
            background-color: #1a1111;
            border: 2px dashed #4a1212;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            color: #7a6a6a;
            font-size: 0.8rem;
        }

        .nombre-carta {
            font-family: 'Cinzel', serif;
            color: #d4af37;
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .badge-rareza {
            background-color: transparent;
            border: 1px solid #d4af37;
            color: #d4af37;
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 10px;
        }

        .badge-tipo {
            background-color: rgba(255,255,255,0.08);
            color: #f0ead6;
            font-size: 0.75rem;
            padding: 4px 12px;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .descripcion-carta {
            color: #a09090;
            font-size: 0.85rem;
            line-height: 1.6;
            border-top: 1px solid #4a1212;
            padding-top: 12px;
            margin-top: 8px;
        }

        .dato-carta {
            color: #f0ead6;
            font-size: 0.85rem;
        }
        .dato-carta strong {
            color: #d4af37;
        }

        /* ── BOTÓN ── */
        .btn-mythic {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            letter-spacing: 1px;
            background: linear-gradient(135deg, #8b0000, #c41230);
            border: none;
            color: #fff;
            padding: 12px 30px;
            border-radius: 8px;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            width: 100%;
            text-decoration: none;
            display: inline-block;
        }
        .btn-mythic:hover {
            background: linear-gradient(135deg, #a00000, #e01535);
            box-shadow: 0 0 20px rgba(230,57,70,0.4);
            color: #fff;
            transform: translateY(-1px);
            text-decoration: none;
        }

        .divider {
            border: none;
            border-top: 1px solid #4a1212;
            margin: 20px 0;
        }
    </style>
</head>
