<!DOCTYPE html>
<html lang="es" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Cartas del Reino - Selección de Zona</title>

    <link rel="stylesheet" th:href="@{/css/globals.css}">

    <style>
        body {
            background-color: var(--game-void);
            color: var(--game-text);
            font-family: 'Roboto', sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .game-panel {
            background-color: var(--game-panel);
            border: 2px solid var(--game-border);
            border-radius: var(--border-radius-general);
            box-shadow: var(--shadow-game);
            padding: 40px 50px;
            text-align: center;
            max-width: 500px;
            width: 90%;
        }

        .game-title {
            color: var(--game-epic);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 0;
            margin-bottom: 10px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        .game-subtitle {
            color: var(--game-muted);
            font-size: 14px;
            margin-bottom: 30px;
        }

        .zonas-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .btn-zona {
            background-color: var(--game-void);
            color: var(--game-text);
            border: 1px solid var(--game-border);
            border-radius: var(--border-radius-general);
            padding: 15px 20px;
            font-size: 18px;
            font-family: 'Roboto', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-zona:hover {
            background-color: var(--game-blood);
            border-color: var(--game-blood-hover);
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(138, 3, 3, 0.4);
        }

        .btn-boss:hover {
            background-color: var(--game-epic);
            border-color: var(--game-epic-hover);
            color: var(--game-void);
            box-shadow: 0 4px 10px rgba(212, 175, 55, 0.4);
        }
    </style>
</head>
<body>

<div class="game-panel">
    <h2 class="game-title">Elige tu destino</h2>
    <p class="game-subtitle">Prepara tu mazo. El peligro te espera en cada rincon.</p>

    <form th:action="@{/iniciar-combate}" method="POST" class="zonas-container">
        <button type="submit" name="zona" value="Bosque Oscuro" class="btn-zona">
            Bosque Oscuro
        </button>

        <button type="submit" name="zona" value="Cueva del Dragón" class="btn-zona btn-boss">
            Cueva del Dragon
        </button>
    </form>
</div>

</body>
</html>