<!DOCTYPE html>
<html lang="es" xmlns:th="http://www.thymeleaf.org">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MythicStack - Tienda</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" th:href="@{/css/main.css}" />
    <style>
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: #ffffff;
            background-image: radial-gradient(circle at 15% 20%, rgba(229, 169, 59, 0.07) 0%, transparent 45%), radial-gradient(circle at 85% 80%, rgba(230, 57, 70, 0.06) 0%, transparent 50%), linear-gradient(rgba(229, 169, 59, 0.015) 1px, transparent 1px), linear-gradient(90deg, rgba(229, 169, 59, 0.015) 1px, transparent 1px), radial-gradient(circle at center, transparent 40%, #040405 110%);
            background-size: 100% 100%, 100% 100%, 45px 45px, 45px 45px, 100% 100%;
        }

        .titulo-seccion {
            color: #e63946;
            font-weight: 800;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(230, 57, 70, 0.4);
        }

        .mythic-card {
            background-color: #131316 !important;
            border: 2px solid #e5a93b !important;
            border-radius: 10px !important;
            position: relative;
            box-shadow: 0px 10px 15px rgba(0, 0, 0, 0.7);
            transition: transform 0.3s, box-shadow 0.2s;
        }

        .mythic-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0 20px rgba(229, 169, 59, 0.4);
        }

        .card-img-container {
            display: flex;
            overflow: hidden;
            border: 3px solid #27272a;
            width: 100%;
            align-items: center;
            justify-content: center;
            box-shadow: 0px 10px 15px 0px #00000080;
        }

        .card-img-custom {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
        }

        .no-art {
            color: #52525b;
            font-size: 0.8rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: 2px dashed #27272a;
            width: 90%;
            height: 90%;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
        }

        .card-title-mythic {
            font-size: 1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 14px;
            color: white;
            text-shadow: 0px 5px 5px black, 0.5px 0px 0px white;
        }

        .badge-rarity {
            background-color: transparent !important;
            border: 1px solid #e5a93b !important;
            color: #e5a93b !important;
            font-size: 0.65rem !important; /* Letra más chica */
            font-weight: 700;
            padding: 4px 8px !important; /* Menos padding horizontal */
            box-shadow: 0px 5px 5px 0px #00000050;
        }

        .badge-type {
            background-color: #27272a !important;
            color: #ffffff !important;
            font-size: 0.65rem !important; /* Letra más chica */
            font-weight: 700;
            text-align: center;
            padding: 4px 8px !important; /* Menos padding horizontal */
            display: flex;
            align-items: center;
            border: 1px solid #fffffa;
            justify-content: center;
            text-shadow: 0.3px 0px 0px white;
        }

        .card-desc-mythic {
            color: #a1a1aa !important;
            font-size: 0.75rem;
            margin-top: 8px;
            min-height: 35px;
        }

        .gap-1 {
            gap: 0.7rem !important;
        }

        button.btn.btn-danger.w-100.fw-bold.shadow-sm {
            background-color: #e63946;
            border-color: #e63946;
            text-transform: uppercase;
            border-radius: 5px;
            text-shadow: 0.3px 0px 0px white, 3px 0px 0px #000000;
            font-size: 20px;
        }

        form {
            box-shadow: 0px 0px 10px 0px #e63946a8;
        }

        .bg-dark.p-2.rounded.mb-3.small.border.border-secondary {
            text-transform: uppercase;
            box-shadow: 0px 5px 15px 0px #00000080;
            text-shadow: 0.3px 0px 0px #f0c10750;
        }

        .text-warning {
            --bs-text-opacity: 1;
            color: rgba(var(--bs-warning-rgb), var(--bs-text-opacity)) !important;
            text-transform: uppercase;
        }

        a.btn.btn-outline-light.btn-sm.ms-4 {
            text-transform: uppercase;
            padding: 5px 20px 5px 20px;
            border-radius: 5px;
            border: 2px solid black;
            box-shadow: 3px 3px 0px black;
            background-color: #e4a83b;
            text-shadow: 0.3px 0px 0px black;
            font-size: 15px;
            text-align: center;
            font-family: 'Montserrat';
            color: black;
        }

        span.navbar-text.text-info.fw-bold.fs-5.ms-4 {
            text-transform: uppercase;
        }

        h2.titulo-seccion.m-0 {
            text-align: center;
            width: 100%;
            font-size: 50px;
            padding: 20px 0px 20px 0px;
            text-shadow: 0px 0px 50px #e63946;
        }

        span.navbar-text.text-warning.fw-bold.fs-5 {
            text-shadow: 0px 0px 15px #ffc107, 3px 3px 0px black;
        }

        span.navbar-text.text-info.fw-bold.fs-5.ms-4 {
            text-shadow: 0px 0px 15px #0dcaf0, 3px 3px 0px black;
        }

        .card-desc-mythic {
            color: #a1a1aa !important;
            font-size: 0.75rem;
            margin-top: 8px;
            min-height: 35px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 17px;
            text-shadow: 3px 3px 5px black;
        }

        .carta-marco {
            width: 100%;
            aspect-ratio: 7 / 10;
            background-color: #2A2A30;
            border: 1px solid #404040;
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .carta-marco img { width: 100%; height: 100%; object-fit: contain; }
        .carta-sin-arte {
            color: #A0A0A5;
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-align: center;
            padding: 8px;
        }
        .carta-marco--grande { max-width: 220px; margin: 0 auto; }
        .grilla-cartas {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 1rem;
        }
        @media (max-width: 991.98px) { .grilla-cartas { grid-template-columns: repeat(5, minmax(0, 1fr)); } }
        @media (max-width: 767.98px) { .grilla-cartas { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
        @media (max-width: 575.98px) { .grilla-cartas { grid-template-columns: repeat(2, minmax(0, 1fr)); } }

    </style>
</head>
<body th:style="|background-image: url('@{/img/TiendaFondo.jpg}'); background-size: cover; background-position: center; background-attachment: fixed;|">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm border-bottom border-secondary">
    <div class="container">
        <a class="navbar-brand titulo-seccion m-0" href="#"
           style="text-shadow: none; font-size: 1.4rem; letter-spacing: 1px;">MythicStack - Tienda</a>
        <div class="d-flex align-items-center">

            <span class="navbar-text text-warning fw-bold fs-5">
                Oro: <span th:text="${session.USUARIO.oro}">0</span>
            </span>

            <span class="navbar-text text-info fw-bold fs-5 ms-4">
                Nivel: <span th:text="${session.USUARIO.nivel}">1</span>
            </span>
            <a th:href="@{/lobby}" class="btn btn-outline-light btn-sm ms-4">Volver al Lobby</a>
        </div>
    </div>
</nav>

<div class="container pb-5">
    <div th:if="${mensaje}" class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <strong th:text="${mensaje}"></strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    <div th:if="${error}" class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <strong th:text="${error}"></strong>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="titulo-seccion m-0">CATÁLOGO DE CARTAS</h2>
    </div>

    <div id="contenedor-cartas" class="grilla-cartas">
        <div class="card-item-node" th:each="carta : ${cartas}" th:attr="data-rareza=${carta.rareza}">
            <div class="card h-100 mythic-card p-3"
                 th:with="rangoJugador=${session.USUARIO != null ? session.USUARIO.nivel : 0}">

                <div class="carta-marco">
                    <img th:if="${carta.imagen != null}" th:src="@{/img/{img}(img=${carta.imagen})}" alt="Imagen de la carta">
                    <span th:if="${carta.imagen == null}" class="carta-sin-arte">Arte no disponible</span>
                </div>

                <div class="card-body d-flex flex-column text-center p-0 mt-2">
                    <h5 class="card-title-mythic" th:text="${carta.nombre}">Nombre</h5>

                    <div class="d-flex justify-content-center gap-1 my-2">
                        <span class="badge badge-rarity" th:text="${carta.rareza != null} ? ${carta.rareza} : 'COMÚN'">Rareza</span>
                        <span class="badge badge-type" th:text="${carta.tipo != null} ? ${carta.tipo} : 'CARTA'">Tipo</span>
                    </div>

                    <p class="card-desc-mythic flex-grow-1"
                       th:text="${carta.descripcion != null} ? ${carta.descripcion} : 'Descripción...'">
                        Descripción...</p>

                    <div class="bg-dark p-2 rounded mb-3 small border border-secondary"
                         style="background-color: #09090b !important;">
                        <div class="d-flex justify-content-between border-bottom border-dark pb-1 mb-1">
                            <span class="text-white-50">Daño:</span>
                            <strong class="text-white">
                                <span th:text="${carta.danoMin}">0</span> - <span th:text="${carta.danoMax}">0</span>
                            </strong>
                        </div>
                        <div class="d-flex justify-content-between border-bottom border-dark pb-1 mb-1">
                            <span class="text-white-50">Defensa:</span>
                            <strong class="text-white">
                                <span th:text="${carta.defensaMin}">0</span> - <span th:text="${carta.defensaMax}">0</span>
                            </strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-warning">Nivel Requerido:</span>
                            <strong class="text-warning" th:text="${carta.nivelDesbloqueo}">1</strong>
                        </div>
                    </div>

                    <h5 class="text-center text-warning fw-bold mb-3 fs-4">
                        <span th:text="${carta.valorOroBase}">0</span> Oro
                    </h5>

                    <div class="mt-auto w-100">
                        <form th:if="${rangoJugador >= carta.nivelDesbloqueo}"
                              th:action="@{'/comprar-carta/' + ${carta.id}}" method="post">
                            <button type="submit" class="btn btn-danger w-100 fw-bold shadow-sm"
                                    style="background-color: #e63946; border-color: #e63946;">
                                Comprar Carta
                            </button>
                        </form>

                        <button th:unless="${rangoJugador >= carta.nivelDesbloqueo}"
                                class="btn btn-secondary w-100 fw-bold" disabled>
                            Nivel Insuficiente
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const contenedor = document.getElementById("contenedor-cartas");
        const nodos = Array.from(contenedor.querySelectorAll(".card-item-node"));
        const pesosRareza = {"Comun": 1, "Poco Comun": 2, "Rara": 3, "Exotica": 4, "Legendaria": 5};

        nodos.sort(function (a, b) {
            const pesoA = pesosRareza[a.getAttribute("data-rareza")] || 99;
            const pesoB = pesosRareza[b.getAttribute("data-rareza")] || 99;
            return pesoA - pesoB;
        });
        nodos.forEach(function (nodo) {
            contenedor.appendChild(nodo);
        });
    });
</script>
</body>
</html>