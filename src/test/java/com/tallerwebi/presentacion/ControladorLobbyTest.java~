package com.tallerwebi.presentacion;

import com.tallerwebi.dominio.ServicioMazo;
import org.junit.Before;
import org.junit.Test;
import org.springframework.web.servlet.ModelAndView;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpSession;
import static org.junit.Assert.assertEquals;
import static org.mockito.Mockito.*;

public class ControladorLobbyTest {

    private ControladorLobby controladorLobby;
    private HttpServletRequest request;

    @Before
    public void init() {
        request = mock(HttpServletRequest.class);

        controladorLobby = new ControladorLobby();
    }

    @Test
    public void alEntrarAlLobbySeMuestraLaVistaCorrecta() {
        // Ejecución
        ModelAndView mav = controladorLobby.irAlLobby(request);

        // Verificación
        assertEquals("lobby", mav.getViewName());
    }
}